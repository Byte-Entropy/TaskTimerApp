{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@task-scheduler/core": ["packages/core/src/index.ts"],
      "@task-scheduler/storage": ["packages/storage/src/index.ts"],
      "@task-scheduler/ui": ["packages/ui/src/index.tsx"]
    }
  }
}
